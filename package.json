{
  "name": "no1-markdown-editor",
  "version": "0.19.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-tauri.mjs dev",
    "dev:web": "vite",
    "dev:tauri": "node scripts/run-tauri.mjs dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "node scripts/run-tests.mjs",
    "test:smoke": "npm run build && node scripts/run-smoke.mjs",
    "test:ai:smoke": "npm run build && node scripts/run-ai-smoke.mjs",
    "test:ai:integration:smoke": "npm run build && node scripts/run-ai-smoke.mjs && node scripts/run-ai-keyboard-smoke.mjs",
    "test:ai:i18n:smoke": "npm run build && node scripts/run-ai-i18n-smoke.mjs",
    "test:ai:keyboard:smoke": "npm run build && node scripts/run-ai-keyboard-smoke.mjs",
    "test:ai:manual:qa:capture": "npm run build && node scripts/run-ai-manual-qa-capture.mjs",
    "test:copy:smoke": "npm run build && node scripts/run-copy-smoke.mjs",
    "test:paste:smoke": "npm run build && node scripts/run-paste-smoke.mjs",
    "test:source:smoke": "npm run build && node scripts/run-source-interaction-smoke.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:draft:advance": "node scripts/advance-release-draft.mjs",
    "release:notes:preview": "node scripts/build-release-body.mjs",
    "release:validate": "node scripts/validate-release.mjs --require-changelog",
    "tauri": "node scripts/run-tauri.mjs",
    "package:win": ".\\scripts\\package-win.cmd",
    "package:mac": "bash ./scripts/package-mac.sh"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6",
    "@codemirror/commands": "^6",
    "@codemirror/lang-markdown": "^6",
    "@codemirror/language": "^6",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6",
    "@codemirror/state": "^6",
    "@codemirror/view": "^6.41.1",
    "@iconify-json/logos": "^1.2.11",
    "@lezer/highlight": "^1",
    "@mermaid-js/mermaid-zenuml": "^0.2.2",
    "@shikijs/rehype": "^4.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "highlight.js": "^11.11.1",
    "i18next": "^23",
    "katex": "^0.16",
    "mermaid": "^11",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^14",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7",
    "rehype-raw": "^7",
    "rehype-sanitize": "^6",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10",
    "remark-gfm": "^4",
    "remark-math": "^6",
    "remark-parse": "^11",
    "remark-rehype": "^11",
    "shiki": "^4.0.2",
    "unified": "^11",
    "zustand": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5",
    "@tauri-apps/cli": "^2",
    "@types/katex": "^0.16",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^5.4.21"
  }
}
