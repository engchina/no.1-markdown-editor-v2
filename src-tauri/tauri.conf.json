{
  "productName": "No.1 Markdown Editor",
  "version": "0.19.4",
  "identifier": "com.no1.markdown-editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev:web -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "No.1 Markdown Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "rank": "Default"
      },
      {
        "ext": [
          "mdx"
        ],
        "name": "MDX Document",
        "description": "MDX document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "rank": "Default"
      },
      {
        "ext": [
          "txt"
        ],
        "name": "Plain Text Document",
        "description": "Plain text document",
        "role": "Editor",
        "mimeType": "text/plain",
        "rank": "Alternate"
      }
    ],
    "windows": {
      "wix": {
        "upgradeCode": "2A43089D-D7E9-533A-B6A3-43EAEF3F3D3F",
        "template": "wix/main.wxs"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
